        {
          "name": "Upload File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Extract filename from response",
                  "var responseText = pm.response.text();",
                  "console.log('Upload response:', responseText);",
                  "",
                  "// Extract filename for next request",
                  "var match = responseText.match(/Uploaded \\d+ chunks for (.+)/);",
                  "if (match) {",
                  "    pm.environment.set('uploaded_filename', match[1]);",
                  "    console.log('Uploaded filename:', match[1]);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select any file to upload"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8080/files",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["files"]
            },
            "description": "Upload a file. The system will split it into chunks and store them across storage nodes."
          },
          "response": []
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
